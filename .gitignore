# =========================
# Python / FastAPI Backend
# =========================

# Virtual environments
venv/
.venv/
env/
ENV/

# Environment variables
.env
.env.*
!.env.example

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# Python build files
build/
dist/
*.egg-info/
.eggs/

# Logs
*.log
logs/

# Testing / coverage
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# Jupyter
.ipynb_checkpoints/

# ML model files
*.pkl
*.joblib
*.h5
*.pt
*.pth
*.onnx

# Local datasets / generated data
*.csv
*.xlsx
*.xls
*.json
*.parquet
*.sqlite
*.db

# But allow useful sample/example files if needed
!sample_*.json
!sample_*.csv
!example_*.json
!example_*.csv


